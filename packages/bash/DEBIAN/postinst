#!/data/data/com.uncode.ide/files/usr/bin/sh
# postinst script for bash

set -e

case "$1" in
    configure)
        # Create symlinks if needed
        BASH_BIN="/data/data/com.uncode.ide/files/usr/bin/bash"
        if [ -f "$BASH_BIN" ]; then
            echo "bash installed successfully."
        fi
    ;;
    abort-upgrade|abort-remove|abort-deconfigure)
    ;;
    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
    ;;
esac

exit 0
